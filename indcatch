local BOOST_STRENGTH = 99999
local function boostLassoStrength()
    local boosted = false
    if getgc then
        pcall(function()
            for _, obj in pairs(getgc(true)) do
                if type(obj) == "table" then
                    if rawget(obj, "lassos") and rawget(obj, "equippedLasso") then
                        rawset(obj.lassos, "Stellar Lasso", true)
                        rawset(obj, "equippedLasso", "Stellar Lasso")
                        boosted = true
                    end
                    if rawget(obj, "strength") and rawget(obj, "model") then
                        if type(rawget(obj, "strength")) == "number" then
                            rawset(obj, "strength", BOOST_STRENGTH)
                            boosted = true
                        end
                    end
                    if rawget(obj, "Basic Lasso") and type(rawget(obj, "Basic Lasso")) == "table" then
                        for name, data in pairs(obj) do
                            if type(data) == "table" and data.strength then
                                data.strength = BOOST_STRENGTH
                                boosted = true
                            end
                        end
                    end
                end
            end
        end)
    end
    pcall(function()
        for _, desc in pairs(ReplicatedStorage:GetDescendants()) do
            if desc:IsA("ModuleScript") and string.find(string.lower(desc.Name), "lasso") then
                pcall(function()
                    local config = require(desc)
                    if type(config) == "table" then
                        for name, data in pairs(config) do
                            if type(data) == "table" and data.strength then
                                data.strength = BOOST_STRENGTH
                                boosted = true
                            end
                        end
                    end
                end)
            end
        end
    end)
    return boosted
end

