local function findStrongestPetAny()
    local strongest, max = nil, 0
    for _, obj in pairs(CollectionService:GetTagged("Roaming")) do
        local s = obj:GetAttribute("Strength")
        local o = obj:GetAttribute("OwnerId")
        local r = obj:GetAttribute("Rarity")
        
        if s and (not o or o == 0) and s > max then
            if not targetBossesEnabled and r == "Boss" then continue end
            if ignoredRarities[r] then continue end
            max = s; strongest = obj
        end
    end
    return strongest
end

local function findStrongestPetCustom(minStrength)
    local strongest, max = nil, minStrength - 1
    for _, obj in pairs(CollectionService:GetTagged("Roaming")) do
        local s = obj:GetAttribute("Strength")
        local o = obj:GetAttribute("OwnerId")
        local r = obj:GetAttribute("Rarity")
        
        if s and s >= minStrength and (not o or o == 0) and s > max then
            if not targetBossesEnabled and r == "Boss" then continue end
            if ignoredRarities[r] then continue end
            max = s; strongest = obj
        end
    end
    return strongest
end

local function rarityAllowedForCatch(rarity)
    for _, allowed in pairs(autoCatchRarities) do
        if allowed then
            return autoCatchRarities[rarity] == true
        end
    end
    return true
end

local function findCatchPet()
    local strongest, max = nil, autoCatchMinStrength - 1
    local seen = {}

    local function check(obj)
        if not obj or seen[obj] then return end
        seen[obj] = true
        local s = tonumber(obj:GetAttribute("Strength")) or 0
        local o = obj:GetAttribute("OwnerId")
        local r = obj:GetAttribute("Rarity")
        if obj:IsDescendantOf(workspace) and s >= autoCatchMinStrength and (not o or o == 0) and s > max and rarityAllowedForCatch(r) then
            if not targetBossesEnabled and r == "Boss" then return end
            max = s; strongest = obj
        end
    end

    for _, folderName in ipairs({"RoamingPets", "SkyIslandPets", "AbyssIslandPets"}) do
        local root = workspace:FindFirstChild(folderName)
        local pets = root and root:FindFirstChild("Pets")
        if pets then
            for _, obj in ipairs(pets:GetChildren()) do
                check(obj)
            end
        end
    end

    return strongest
end

local function cleanupLassoVisuals()
    local char = player.Character
    local containers = {char, workspace}
    for _, container in ipairs(containers) do
        if not container then continue end
        for _, obj in ipairs(container:GetDescendants()) do
            local name = string.lower(obj.Name)
            local className = string.lower(obj.ClassName)
            local looksLikeLasso = name:find("lasso") or name:find("rope") or name:find("tether") or className == "beam" or className == "trail"
            if looksLikeLasso and not obj:FindFirstAncestorWhichIsA("Tool") then
                if obj:IsA("BasePart") or obj:IsA("Beam") or obj:IsA("Trail") or obj:IsA("Attachment") or obj:IsA("Model") then
                    pcall(function() obj:Destroy() end)
                end
            end
        end
    end
end

local function unequipLassoVisual()
    local equipLassoVisual = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("equipLassoVisual")
    if equipLassoVisual then
        pcall(function() equipLassoVisual:InvokeServer(nil) end)
        pcall(function() equipLassoVisual:InvokeServer() end)
    end
    cleanupLassoVisuals()
end

