local function getEquippedOrBackpackLasso()
    local char = player.Character
    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("lasso") then return tool end
        end
    end
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("lasso") then return tool end
        end
    end
    return nil
end

local function attemptCatchPet(pet)
    if not pet or not pet.Parent then return false end
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not Remotes then return false end

    local equipLassoVisual = Remotes:FindFirstChild("equipLassoVisual")
    local throwLasso = Remotes:FindFirstChild("ThrowLasso")
    local minigameRequest = Remotes:FindFirstChild("minigameRequest")
    local updateProgress = Remotes:FindFirstChild("UpdateProgress")
    if not throwLasso or not minigameRequest or not updateProgress then return false end

    unequipLassoVisual()
    local lasso = getEquippedOrBackpackLasso()
    if equipLassoVisual and lasso then pcall(function() equipLassoVisual:InvokeServer(lasso) end) end

    local ok, pivot = pcall(function() return pet:GetPivot() end)
    if not ok or not pivot then return false end
    local dir = Vector3.new(pivot.Position.X - root.Position.X, 0, pivot.Position.Z - root.Position.Z)
    dir = dir.Magnitude > 0 and dir.Unit or root.CFrame.LookVector

    pcall(function() throwLasso:FireServer(0.9, dir) end)
    task.wait(0.15)
    task.spawn(function()
        pcall(function() minigameRequest:InvokeServer(pet, pivot) end)
    end)
    task.wait(0.15)
    unequipLassoVisual()

    local isBoss = pet:GetAttribute("Rarity") == "Boss"
    if isBoss then
        for _ = 1, 60 do
            if not autoCatchEnabled or not pet.Parent then break end
            pcall(function() updateProgress:FireServer(1) end)
            pcall(function() updateProgress:FireServer(2) end)
            task.wait()
        end
    else
        for _, v in ipairs({25, 25, 61.66666666666668, 100, 100}) do
            pcall(function() updateProgress:FireServer(v) end)
            task.wait()
        end
    end

    unequipLassoVisual()
    return true
end

local function isPlayerBusy()
    for _, obj in pairs(CollectionService:GetTagged("Roaming")) do
        local o = obj:GetAttribute("OwnerId")
        if o == player.UserId then return true end
    end
    local pg = player:FindFirstChild("PlayerGui")
    if pg then
        for _, gui in pairs(pg:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Enabled then
                local name = string.lower(gui.Name)
                if string.find(name, "minigame") or string.find(name, "catch") or string.find(name, "lasso") then
                    return true
                end
            end
        end
        local mgFrame = pg:FindFirstChild("Minigame", true) or pg:FindFirstChild("Catching", true) or pg:FindFirstChild("Minigames", true)
        if mgFrame and mgFrame:IsA("GuiObject") and mgFrame.Visible then
            local sGui = mgFrame:FindFirstAncestorOfClass("ScreenGui")
            if sGui and sGui.Enabled then return true end
        end
    end
    return false
end

local function teleportTo(cf)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then root.CFrame = cf + Vector3.new(0, 5, 0) end
end

local function scanNextCatchMapArea(root)
    if not root or not autoCatchMapScanEnabled then return end
    if os.clock() - lastCatchMapScan < autoCatchMapScanDelay then return end
    lastCatchMapScan = os.clock()
    catchMapScanIndex = (catchMapScanIndex % #catchMapScanLocations) + 1
    root.CFrame = catchMapScanLocations[catchMapScanIndex] + Vector3.new(0, 6, 0)
end

local function getFishingSpot()
    return fishingSpots[selectedFishingSpot] or fishingSpots["Lost Docks"]
end

local function getSelectedFishingBaitList()
    local list = {}
    for _, bait in ipairs(baitList) do
        if selectedFishingBaits[bait] then table.insert(list, bait) end
    end
    if #list == 0 and selectedFishingBait ~= "" then table.insert(list, selectedFishingBait) end
    return list
end

local function getNextFishingBait()
    local list = getSelectedFishingBaitList()
    if #list == 0 then return nil end
    fishingBaitIndex = (fishingBaitIndex % #list) + 1
    selectedFishingBait = list[fishingBaitIndex]
    return selectedFishingBait
end

local function getPetInventory()
    local remotes = ReplicatedStorage:WaitForChild("Remotes")
    local getPetInventoryRemote = remotes:FindFirstChild("getPetInventory")
    if not getPetInventoryRemote then return nil end
    local ok, inv = pcall(function() return getPetInventoryRemote:InvokeServer() end)
    if ok and type(inv) == "table" then return inv end
    return nil
end

local function hasSelectedSellRarity()
    for _, selected in pairs(autoSellPetRarities) do
        if selected then return true end
    end
    return false
end

local function sellPetByGuid(guid, petData)
    local remotes = ReplicatedStorage:WaitForChild("Remotes")
    local collectPetCash = remotes:FindFirstChild("collectPetCash")
    local sellPet = remotes:FindFirstChild("sellPet")
    if not sellPet or not guid then return false end
    if collectPetCash then
        pcall(function() collectPetCash:FireServer(guid) end)
        task.wait(0.1)
    end
    pcall(function() sellPet:InvokeServer(guid) end)
    task.wait(0.6)
    local inv = getPetInventory()
    return type(inv) == "table" and inv[guid] == nil
end

local function logFailedSell(guid, pet)
    if not writefile or type(pet) ~= "table" then return end
    local line = table.concat({
        tostring(os.date("%H:%M:%S")),
        tostring(guid),
        tostring(pet.name or pet.Name),
        tostring(pet.rarity or pet.Rarity),
        "rev=" .. tostring(pet.revToCollect),
        "offline=" .. tostring(pet.offlineRevToBeCollected),
        "price=" .. tostring(pet.sellPrice),
    }, " | ")
    pcall(function()
        local old = isfile and isfile("IndraHub_FailedSellPets.txt") and readfile("IndraHub_FailedSellPets.txt") or ""
        writefile("IndraHub_FailedSellPets.txt", old .. line .. "\n")
    end)
end

local function findNextSellPet(inv)
    for guid, pet in pairs(inv) do
        if type(pet) == "table" then
            local rarity = pet.rarity or pet.Rarity
            guid = pet.guid or pet.Guid or guid
            if rarity and autoSellPetRarities[rarity] then
                return guid, pet
            end
        end
    end
    return nil, nil
end

