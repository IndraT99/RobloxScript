local breedStationPos1 = vector.create(-169.56399536132812, 12, -2956.529052734375)
local breedStationPos2 = vector.create(-162.60342407226562, 12, -2930.13330078125)

local breedPetList = {}       -- { {name="Cat (abc123)", instance=<Instance>}, ... }
local breedPetNames = {}      -- { "Cat (abc123)", ... }
local selectedBreedPet1 = nil -- instance
local selectedBreedPet2 = nil -- instance
local breedPetDropdown1 = nil
local breedPetDropdown2 = nil

local function findOwnPenNumber()
    local pensFolder = workspace:FindFirstChild("PlayerPens")
    if not pensFolder then return nil end

    for _, pen in ipairs(pensFolder:GetChildren()) do
        local owner = pen:GetAttribute("Owner") or pen:GetAttribute("OwnerName")
        local ownerId = pen:GetAttribute("OwnerId") or pen:GetAttribute("UserId")
        if owner == player.Name or ownerId == player.UserId then
            return tostring(pen.Name)
        end
    end

    return nil
end

local function getBreedPen()
    local pensFolder = workspace:FindFirstChild("PlayerPens")
    if not pensFolder then return nil end

    if breedPenNumber == "auto" or breedPenNumber == "" then
        local ownPen = findOwnPenNumber()
        if ownPen then breedPenNumber = ownPen end
    end

    return pensFolder:FindFirstChild(tostring(breedPenNumber))
end

local function toBreedVector(pos)
    return vector.create(pos.X, pos.Y, pos.Z)
end

local function scanPenPets()
    breedPetList = {}
    breedPetNames = {}
    local pen = getBreedPen()
    if not pen then return end
    local petsFolder = pen:FindFirstChild("Pets")
    if not petsFolder then return end
    
    for _, pet in ipairs(petsFolder:GetChildren()) do
        local petName = pet:GetAttribute("Name") or pet.Name
        local shortId = string.sub(pet.Name, 1, 8)
        local cooldownEnd = tonumber(pet:GetAttribute("CooldownEnd")) or 0
        local cooldownText = cooldownEnd > os.time() and " [Cooldown]" or ""
        local displayName = petName .. " (" .. shortId .. ")" .. cooldownText
        table.insert(breedPetList, {name = displayName, instance = pet})
        table.insert(breedPetNames, displayName)
    end

    local firstReady = nil
    local secondReady = nil
    for _, petInfo in ipairs(breedPetList) do
        local pet = petInfo.instance
        local cooldownEnd = tonumber(pet:GetAttribute("CooldownEnd")) or 0
        if cooldownEnd <= os.time() then
            if not firstReady then
                firstReady = pet
            elseif (pet:GetAttribute("Name") or pet.Name) ~= (firstReady:GetAttribute("Name") or firstReady.Name) then
                secondReady = pet
                break
            elseif not secondReady then
                secondReady = pet
            end
        end
    end

    selectedBreedPet1 = selectedBreedPet1 or firstReady or (breedPetList[1] and breedPetList[1].instance)
    selectedBreedPet2 = selectedBreedPet2 or secondReady or (breedPetList[2] and breedPetList[2].instance)
end

local function refreshBreedPetDropdowns()
    for _, dropdown in ipairs({breedPetDropdown1, breedPetDropdown2}) do
        if dropdown then
            pcall(function()
                if dropdown.Refresh then dropdown:Refresh(breedPetNames) end
            end)
            pcall(function()
                if dropdown.SetValues then dropdown:SetValues(breedPetNames) end
            end)
            pcall(function()
                if dropdown.Update then dropdown:Update({Values = breedPetNames}) end
            end)
        end
    end
end

local function findBreedStations()
    local pen = getBreedPen()
    if not pen then return nil, nil end
    
    local breedingFolder = pen:FindFirstChild("Breeding")
    if breedingFolder then
        local parts = {}
        for _, child in ipairs(breedingFolder:GetDescendants()) do
            if child:IsA("BasePart") then table.insert(parts, child) end
        end
        if #parts >= 2 then
            return toBreedVector(parts[1].Position), toBreedVector(parts[2].Position)
        elseif #parts == 1 then
            local p = parts[1].Position
            return toBreedVector(p), toBreedVector(p + Vector3.new(5, 0, 0))
        end
    end

    if selectedBreedPet1 and selectedBreedPet2 then
        local ok1, pivot1 = pcall(function() return selectedBreedPet1:GetPivot() end)
        local ok2, pivot2 = pcall(function() return selectedBreedPet2:GetPivot() end)
        if ok1 and ok2 then
            return toBreedVector(pivot1.Position), toBreedVector(pivot2.Position)
        end
    end

    local storeFolder = pen:FindFirstChild("Store")
    local nest = storeFolder and storeFolder:FindFirstChild("Nest", true)
    if nest then
        local ok, pivot = pcall(function() return nest:GetPivot() end)
        if ok and pivot then
            local p = pivot.Position
            return toBreedVector(p + Vector3.new(-3, 0, 0)), toBreedVector(p + Vector3.new(3, 0, 0))
        end
    end

    local eggsFolder = pen:FindFirstChild("Eggs")
    if eggsFolder then
        local eggPart = eggsFolder:FindFirstChildWhichIsA("BasePart", true)
        if eggPart then
            local p = eggPart.Position
            return toBreedVector(p + Vector3.new(-3, 0, 0)), toBreedVector(p + Vector3.new(3, 0, 0))
        end
    end

    -- Search for breeding station parts in the pen
    local stations = {}
    for _, child in ipairs(pen:GetDescendants()) do
        if child:IsA("BasePart") then
            local name = string.lower(child.Name)
            -- More specific names commonly used for breeding pads
            if string.find(name, "pad") or string.find(name, "seat") or string.find(name, "stand") or string.find(name, "nursery") or string.find(name, "pedestal") then
                table.insert(stations, child)
            end
        end
    end
    
    -- Sort by name or distance if needed, but for now just pick the first two found
    if #stations >= 2 then
        local p1 = stations[1].Position
        local p2 = stations[2].Position
            return toBreedVector(p1), toBreedVector(p2)
    elseif #stations == 1 then
        local p1 = stations[1].Position
        -- If only one found, assume second is nearby
        return toBreedVector(p1), toBreedVector(p1 + Vector3.new(5, 0, 0))
    end

    local petsFolder = pen:FindFirstChild("Pets")
    if petsFolder then
        local firstPet = petsFolder:FindFirstChildWhichIsA("Model")
        if firstPet then
            local ok, pivot = pcall(function() return firstPet:GetPivot() end)
            if ok and pivot then
                local p = pivot.Position
                return toBreedVector(p + Vector3.new(-3, 0, 0)), toBreedVector(p + Vector3.new(3, 0, 0))
            end
        end
    end

    return nil, nil
end

local function doBreedRequest()
    local now = os.clock()
    if now - lastBreedRequestAt < breedRequestCooldown then
        return false, "Local debounce: wait " .. math.ceil(breedRequestCooldown - (now - lastBreedRequestAt)) .. "s"
    end

    if not selectedBreedPet1 or not selectedBreedPet2 then
        return false, "Select 2 pets first from dropdowns"
    end
    if selectedBreedPet1 == selectedBreedPet2 then
        return false, "Cannot breed a pet with itself"
    end
    if not selectedBreedPet1:IsDescendantOf(workspace) then
        return false, "Pet 1 no longer exists in pen"
    end
    if not selectedBreedPet2:IsDescendantOf(workspace) then
        return false, "Pet 2 no longer exists in pen"
    end
    
    -- Try dynamic positions first, fallback to hardcoded
    local pos1, pos2 = findBreedStations()
    if not pos1 then
        pos1 = breedStationPos1
        pos2 = breedStationPos2
    end
    
    local breedRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("breedRequest")
    lastBreedRequestAt = os.clock()
    local result, reason = breedRemote:InvokeServer(
        selectedBreedPet1, selectedBreedPet2,
        pos1,
        pos2
    )

    if result == false then
        return false, "Server rejected breed request" .. (reason and (": " .. tostring(reason)) or ". Try different pets.")
    end

    return true, result or reason
end

local function ensureOwnBreedPen()
    local pen = getBreedPen()
    local owner = pen and (pen:GetAttribute("Owner") or pen:GetAttribute("OwnerName"))
    local ownerId = pen and (pen:GetAttribute("OwnerId") or pen:GetAttribute("UserId"))
    if not pen or (owner ~= player.Name and ownerId ~= player.UserId) then
        local ownPen = findOwnPenNumber()
        if ownPen then breedPenNumber = ownPen end
    end
end

